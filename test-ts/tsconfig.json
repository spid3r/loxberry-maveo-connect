{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "types": ["node", "mocha"],
    "noUnusedParameters": false
  },
  "include": ["./**/*.ts", "../service/src/**/*.ts"]
}

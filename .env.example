# --- LoxBerry (HTTP basic auth + admin; used by playwright + loxberry-client) ---
LOXBERRY_BASE_URL=http://loxberry.local
LOXBERRY_USERNAME=admin
LOXBERRY_PASSWORD=your-admin-password
# Admin “secure PIN” when LoxBerry asks for confirmations (CLI deploy expects it set).
LOXBERRY_SECURE_PIN=12345

# Optional overrides
# PLUGIN_FOLDER=maveoconnect
# E2E_VERBOSE=1
# E2E_SKIP_UNINSTALL=1

# --- Maveo account (full E2E: fills Settings form; mirrors plugin/webfrontend/htmlauth/settings.php) ---
# Required for destructive E2E (full-lifecycle.spec.ts): login + MQTT wait
MAVO_EMAIL=maveo@example.com
MAVO_PASSWORD=your-maveo-password
# Optional — empty uses library defaults / „Sticks laden“ in Settings after save
# MAVO_COGNITO_IDENTITY_POOL_ID=
# MAVO_THING_NAME=your-stick-serial-or-thing-name

# Optional
# MAVO_COGNITO_CLIENT_ID=
# MAVO_REGION=us-west-2
# Set to 1 only if your stack uses Cognito/AWS test endpoints
# MAVO_USE_TEST_ENDPOINTS=0

# Start/restart Node-Daemon nach Install und nach Settings-Save (lädt settings.json neu).
# v1.1.0+: Der Daemon wird via /opt/loxberry/system/daemons/plugins/maveoconnect (LSB Init-Skript)
# und sudoers verwaltet — postroot.sh restartet ihn automatisch nach Install/Upgrade,
# settings.php SIGHUPt nach jedem Save. SSH-Override nur falls die Hooks aus irgendeinem
# Grund streiken oder du eine ältere Version updates.
#
# Examples (adapt zu deinem LB-Pfad/User):
# E2E_SSH_RESTART_CMD=ssh loxberry@loxberry.local "sudo /opt/loxberry/system/daemons/plugins/maveoconnect restart"

# ---
# Timing (optional ms)
# E2E_DAEMON_UP_MS=120000
# E2E_POST_INSTALL_MS=25000
# E2E_MQTT_WAIT_MS=180000
# E2E_MQTT_POLL_MS=2500

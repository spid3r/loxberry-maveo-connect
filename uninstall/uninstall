#!/bin/bash
# Uninstall only (not on update). As root.
# Args: $1 tmp $2 pluginname $3 plugin root $4 version $5 LBHOMEDIR
set +e
PLUGINROOT="${3:-}"
PLUGINNAME="${2:-maveoconnect}"
PIDFILE="/var/run/${PLUGINNAME}_node.pid"

if [ -n "$PLUGINROOT" ] && [ -f "$PLUGINROOT/daemon.sh" ]; then
  bash "$PLUGINROOT/daemon.sh" stop 2>/dev/null || true
fi

if [ -f "$PIDFILE" ]; then
  pid=$(cat "$PIDFILE" 2>/dev/null || true)
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    sleep 1
    kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$PIDFILE"
fi

echo "Maveo Connect uninstall: daemon stopped."
exit 0

  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "build": "esbuild src/service.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/service.mjs --packages=bundle --legal-comments=none",
